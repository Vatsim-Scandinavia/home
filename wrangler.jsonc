{
  // Astro + @astrojs/cloudflare (on-demand / server islands).
  // https://developers.cloudflare.com/workers/framework-guides/web-apps/astro/
  // `main` is required: without it, only static assets deploy and /_server-islands/* returns 404.
  "name": "home",
  "main": "./dist/_worker.js/index.js",
  "compatibility_date": "2025-04-01",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist",
    "not_found_handling": "404-page",
  },
}
